# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
build/
dist/
.eggs/
.installed.cfg

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ---- Testing / coverage ----
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.cache

# ---- Jupyter ----
.ipynb_checkpoints/
*-checkpoint.ipynb

# ---- Generated outputs ----
# Pickles and figures are generated by fits and analyses.
# Keep results/ directory but don't track its contents (except .gitkeep).
results/*
!results/.gitkeep

# Manuscript build artefacts
manuscript/*.aux
manuscript/*.log
manuscript/*.out
manuscript/*.toc
manuscript/*.pdf
!manuscript/figures/

# Notes are personal — let user track selectively.
# (Default: track. Override per-file in notes/.gitignore if needed.)
